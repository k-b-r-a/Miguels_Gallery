{
  "name": "miguels-gallery",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "src/index.tsx",
  "module": "src/index.tsx",
  "scripts": {
    "dev:frontend": "bun --hot run src/index.tsx",
    "dev:backend": "node --watch backend/index.mjs",
    "dev": "concurrently -n \"BACKEND,FRONTEND\" -c \"magenta,green\" \"npm run dev:backend\" \"npm run dev:frontend\"",
    "start": "NODE_ENV=production bun src/index.tsx",
    "build": "bun run build.ts"
  },
  "dependencies": {
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/modifiers": "^9.0.0",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@emotion/react": "^11.14.0",
    "@emotion/styled": "^11.14.0",
    "@headlessui/react": "^2.2.0",
    "@heroicons/react": "^2.2.0",
    "@mui/icons-material": "^7.0.1",
    "@mui/material": "^7.0.1",
    "@tailwindcss/cli": "^4.2.4",
    "@tailwindcss/node": "^4.2.4",
    "@tailwindcss/oxide": "^4.2.4",
    "bcryptjs": "^3.0.3",
    "browser-image-compression": "^2.0.2",
    "bun-plugin-tailwind": "^0.0.14",
    "cloudinary": "^2.10.0",
    "cors": "^2.8.6",
    "dotenv": "^16.4.7",
    "express": "5.1.0",
    "framer-motion": "^12.38.0",
    "jsonwebtoken": "^9.0.3",
    "mongodb": "^6.15.0",
    "multer": "^2.1.1",
    "multer-storage-cloudinary": "^4.0.0",
    "picocolors": "^1.1.1",
    "react": "^19",
    "react-dom": "^19",
    "tailwindcss": "^4.2.4"
  },
  "devDependencies": {
    "@eslint/js": "^9.24.0",
    "@types/bun": "latest",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "concurrently": "^9.2.1",
    "eslint": "^9.24.0",
    "eslint-plugin-react": "^7.37.4",
    "globals": "^16.0.0",
    "typescript-eslint": "^8.28.0"
  },
  "trustedDependencies": [
    "@parcel/watcher"
  ]
}
